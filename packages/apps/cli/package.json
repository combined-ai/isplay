{
  "name": "isplay",
  "version": "0.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "isplay": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@isplay/api-client": "0.3.0",
    "@isplay/server": "0.3.0",
    "@isplay/worker": "0.3.0",
    "commander": "^14.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isplay/isplay.git"
  },
  "bugs": {
    "url": "https://github.com/isplay/isplay/issues"
  },
  "homepage": "https://isplay.dev",
